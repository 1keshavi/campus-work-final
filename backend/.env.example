PORT=5000
MONGO_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/myDatabase?retryWrites=true&w=majority
# If SRV DNS lookups fail in your environment, use the standard Atlas URI format instead:
# MONGO_URI=mongodb://username:password@host1.mongodb.net:27017,host2.mongodb.net:27017,host3.mongodb.net:27017/myDatabase?authSource=admin&replicaSet=atlas-xxxxx-shard-0&tls=true&retryWrites=true&w=majority
